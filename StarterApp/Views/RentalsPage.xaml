<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StarterApp.Views.RentalsPage"
    Title="Rentals">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="18">

            <Label
                Text="Rental Requests"
                FontSize="26"
                FontAttributes="Bold" />

            <!-- incoming requests -->
            <Label
                Text="Incoming"
                FontSize="20"
                FontAttributes="Bold" />

            <CollectionView ItemsSource="{Binding IncomingRentals}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Frame Margin="0,8,0,0" Padding="12">

                            <VerticalStackLayout Spacing="6">

                                <Label
                                    Text="{Binding Item.Title}"
                                    FontAttributes="Bold"
                                    FontSize="16" />

                                <Label
                                    Text="{Binding Status}" />

                                <HorizontalStackLayout Spacing="10">

                                    <Button
                                        Text="Approve"
                                        BackgroundColor="DarkGreen"
                                        TextColor="White"
                                        Clicked="ApproveButton_Clicked"
                                        CommandParameter="{Binding Id}" />

                                    <Button
                                        Text="Reject"
                                        BackgroundColor="DarkRed"
                                        TextColor="White"
                                        Clicked="RejectButton_Clicked"
                                        CommandParameter="{Binding Id}" />

                                </HorizontalStackLayout>

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- outgoing requests -->
            <Label
                Text="Outgoing"
                FontSize="20"
                FontAttributes="Bold"
                Margin="0,15,0,0" />

            <CollectionView ItemsSource="{Binding OutgoingRentals}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Frame Margin="0,8,0,0" Padding="12">

                            <VerticalStackLayout Spacing="4">

                                <Label
                                    Text="{Binding Item.Title}"
                                    FontAttributes="Bold"
                                    FontSize="16" />

                                <Label
                                    Text="{Binding Status}" />

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>